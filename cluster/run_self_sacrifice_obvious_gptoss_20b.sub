# HTCondor submit: gpt-oss-20b self-sacrifice DCOP framing sweep
# (3 profiles x 2 framings x 5 seeds = 30 runs, concurrent against one server). Submit with:
#   condor_submit_bid <bid> cluster/run_self_sacrifice_gptoss_20b.sub

executable = /bin/bash
arguments  = /fast/jtaraz/LIARS/colosseum-detection/cluster/run_self_sacrifice_obvious_gptoss_20b.sh

environment = "HF_TOKEN=$ENV(HF_TOKEN)"

error  = self_sacrifice_obvious_gptoss_20b_$(Cluster).err
output = self_sacrifice_obvious_gptoss_20b_$(Cluster).out
log    = self_sacrifice_obvious_gptoss_20b_$(Cluster).log

# gpt-oss-20b MXFP4 ~13 GB -> 1x H100-80GB (tensor_parallel_size: 1 in the YAML).
request_gpus   = 1
requirements   = TARGET.CUDADeviceName == "NVIDIA H100 80GB HBM3"
request_memory = 65536
request_cpus   = 8
request_disk   = 200G
+BypassLXCfs   = "true"
queue
