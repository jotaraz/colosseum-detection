# (4 cost tables x 2 framings x 5 seeds x 3 samples = 120 runs, concurrent against one server).
# Submit with:  condor_submit_bid <bid> cluster/run_self_sacrifice_veryego_gptoss_120b.sub

executable = /bin/bash
arguments  = /fast/jtaraz/LIARS/colosseum-detection/cluster/run_self_sacrifice_veryego_gptoss_120b.sh

environment = "HF_TOKEN=$ENV(HF_TOKEN)"

error  = self_sacrifice_veryego_gptoss_120b_$(Cluster).err
output = self_sacrifice_veryego_gptoss_120b_$(Cluster).out
log    = self_sacrifice_veryego_gptoss_120b_$(Cluster).log

