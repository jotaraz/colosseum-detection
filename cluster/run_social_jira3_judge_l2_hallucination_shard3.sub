# CPU-only level-2 (Hallucination) confirmation judge, SHARDED across 3 nodes over the 5 completed
# v5_quit23 confsweep trees (all but glm-nodecoy). 3 shards x 16 workers = 48 concurrent Azure
# gpt-5.4 calls — a measured step up from the proven-clean single-node 16 after pass B (a competing
# judge job) freed rate-limit headroom. NOT the 96-concurrent config that hit ~16% 429s under
# contention. Resumable/idempotent via --skip-existing. Writes judge_l2_hallucination.json per leaf.
# Submit (needs a valid login-node kerberos ticket):
#   condor_submit_bid 50 cluster/run_social_jira3_judge_l2_hallucination_shard3.sub
executable = /bin/bash
arguments  = /fast/jtaraz/LIARS/colosseum-detection/cluster/run_social_jira3_judge_l2_hallucination.sh $(Process) 3

error  = /fast/jtaraz/cluster_stuff/judge/l2hall_s$(Process)of3_$(Cluster).err
output = /fast/jtaraz/cluster_stuff/judge/l2hall_s$(Process)of3_$(Cluster).out
log    = /fast/jtaraz/cluster_stuff/judge/l2hall_shard3_$(Cluster).log

request_gpus   = 0
request_cpus   = 4
request_memory = 8192
request_disk   = 4G
+BypassLXCfs   = "true"

queue 3
