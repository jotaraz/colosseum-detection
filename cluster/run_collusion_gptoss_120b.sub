# HTCondor submit file: openai/gpt-oss-120b (native MXFP4, ~63 GB) collusion sweep.
# Fits on 2x H100-80GB at tensor_parallel_size: 2.
# Submit with:  condor_submit_bid <bid> cluster/run_collusion_gptoss_120b.sub
# (HF_TOKEN is optional -- gpt-oss-120b is public Apache-2.0; passed through harmlessly.)

executable = /bin/bash
arguments  = /fast/jtaraz/LIARS/colosseum-detection/cluster/run_collusion_gptoss_120b.sh

environment = "HF_TOKEN=$ENV(HF_TOKEN)"

error  = gptoss_120b_$(Cluster).err
output = gptoss_120b_$(Cluster).out
log    = gptoss_120b_$(Cluster).log

# 2x H100-80GB. tensor_parallel_size: 2 in the YAML must match request_gpus.
request_gpus   = 2
requirements   = TARGET.CUDADeviceName == "NVIDIA H100 80GB HBM3"
request_memory = 131072
request_cpus   = 8
request_disk   = 200G
+BypassLXCfs   = "true"
queue
