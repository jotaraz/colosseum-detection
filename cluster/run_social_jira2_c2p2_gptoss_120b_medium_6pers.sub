# HTCondor submit: gpt-oss-120b (medium, NON-robust) social-jira2 c2p2 6PERS sweep
# (3 feelings x 2 cells x 6 personalities x 2 seeds x 3 samples = 216 runs). Submit with:
#   condor_submit_bid 100 cluster/run_social_jira2_c2p2_gptoss_120b_medium_3feelings.sub

executable = /bin/bash
arguments  = /fast/jtaraz/LIARS/colosseum-detection/cluster/run_social_jira2_c2p2_gptoss_120b_medium_6pers.sh

environment = "HF_TOKEN=$ENV(HF_TOKEN)"

error  = social_jira2_c2p2_gptoss_120b_medium_6pers_$(Cluster).err
output = social_jira2_c2p2_gptoss_120b_medium_6pers_$(Cluster).out
log    = social_jira2_c2p2_gptoss_120b_medium_6pers_$(Cluster).log

# gpt-oss-120b MXFP4 ~63 GB -> 2x H100-80GB (tensor_parallel_size: 2 in the YAML).
request_gpus   = 2
requirements   = (TARGET.CUDADeviceName == "NVIDIA H100 80GB HBM3") && (TARGET.Machine =!= "i105.internal.cluster.is.localnet") && (TARGET.Machine =!= "i107.internal.cluster.is.localnet") && (TARGET.Machine =!= "i101.internal.cluster.is.localnet")
request_memory = 131072
request_cpus   = 8
request_disk   = 200G
+BypassLXCfs   = "true"
queue
