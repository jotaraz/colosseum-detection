# CPU-only judge sweep, SECOND batch: 12 shards over glm decoy-ON + glm nodecoy + qwen nodecoy.
# --skip-existing + metrics.json guard -> judges only finished leaves; re-submit later to top up
# stragglers that finish after this run. Submit (needs a valid login-node kerberos ticket):
#   condor_submit_bid 50 cluster/run_social_jira3_judge_shard2.sub
executable = /bin/bash
arguments  = /fast/jtaraz/LIARS/colosseum-detection/cluster/run_social_jira3_judge_shard2.sh $(Process) 12 --skip-existing --workers 16

error  = /fast/jtaraz/cluster_stuff/judge/pass2_shard_$(Process)_$(Cluster).err
output = /fast/jtaraz/cluster_stuff/judge/pass2_shard_$(Process)_$(Cluster).out
log    = /fast/jtaraz/cluster_stuff/judge/pass2_judge_$(Cluster).log

request_gpus   = 0
request_cpus   = 4
request_memory = 8192
request_disk   = 4G
+BypassLXCfs   = "true"

queue 12
