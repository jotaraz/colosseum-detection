# DO NOT PUT SECRETS IN THIS FILE.
# Copy this template to `.env` and fill in your keys with:
#
#   cp -n .env.example .env
#
# `.env` is gitignored.

# Provider API keys (set what you use).
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
TOGETHER_API_KEY=
FIREWORKS_API_KEY=

# Some DCOP environments require a CoLLAB checkout.
# If you installed terrarium-agents from PyPI (no git submodules), point Terrarium at CoLLAB:
TERRARIUM_COLLAB_PATH=

# HuggingFace model cache location.
# NOTE: Terrarium only auto-loads this .env inside the API clients (openai/anthropic/...),
# NOT in the vLLM runtime. For local vLLM runs, set HF_HOME either via the
# `llm.vllm.env` block in the experiment YAML, or by exporting it in your shell
# before launching (e.g. `export HF_HOME=/scratch/$USER/hf_cache`).
# HF_HOME covers everything; HF_HUB_CACHE narrowly overrides just the hub cache.
HF_HOME=
# HF_HUB_CACHE=
# Token only needed for gated/private models (Qwen2.5 is public, so optional):
# HF_TOKEN=